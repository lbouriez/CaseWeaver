  },
  "dependencies": {
    "@caseweaver/ai-config": "workspace:*",
    "@caseweaver/ai-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.19.7",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
