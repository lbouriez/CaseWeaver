  contentSha256          String?   @map("content_sha256")
  byteLength             Int?      @map("byte_length")
  contentType            String?   @map("content_type")
  eventCount             Int?      @map("event_count")
  generatedAt            DateTime? @map("generated_at") @db.Timestamptz(6)
  failureCode            String?   @map("failure_code")
  generationClaimToken   String?   @map("generation_claim_token")
  generationClaimedUntil DateTime? @map("generation_claimed_until") @db.Timestamptz(6)
  generationAttempts     Int       @default(0) @map("generation_attempts")
  deletionClaimToken     String?   @map("deletion_claim_token")
  deletionClaimedUntil   DateTime? @map("deletion_claimed_until") @db.Timestamptz(6)
  deletionAttempts       Int       @default(0) @map("deletion_attempts")
