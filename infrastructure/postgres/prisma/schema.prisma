/** Server-only state for bounded, redacted diagnostics exports. */
model AdministrationDiagnosticExport {
  id                     String    @id
  workspaceId            String    @map("workspace_id")
  requestedByPrincipalId String    @map("requested_by_principal_id")
  status                 String
  eventCutoffAt          DateTime  @map("event_cutoff_at") @db.Timestamptz(6)
  maximumEvents          Int       @map("maximum_events")
  expiresAt              DateTime  @map("expires_at") @db.Timestamptz(6)
