{
  "name": "@caseweaver/postgres",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "prisma generate && tsc --project tsconfig.json",
    "typecheck": "prisma generate && tsc --noEmit --project tsconfig.json",
    "test": "vitest run --passWithNoTests --exclude \"src/**/*.integration.test.ts\"",
    "test:integration": "node --input-type=module -e \"if (!process.env.DATABASE_URL) throw new Error('PostgreSQL integration tests require DATABASE_URL.');\" && prisma migrate deploy --schema prisma/schema.prisma && vitest run --no-file-parallelism src/postgres.integration.test.ts src/ai/postgres-ai.integration.test.ts",
    "prisma:generate": "prisma generate --schema prisma/schema.prisma",
    "prisma:migrate:deploy": "prisma migrate deploy --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@caseweaver/ai-execution": "workspace:*",
    "@caseweaver/application": "workspace:*",
    "@caseweaver/domain": "workspace:*",
    "@caseweaver/knowledge": "workspace:*",
    "@caseweaver/scheduling": "workspace:*",
    "@caseweaver/security": "workspace:*",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@caseweaver/ai-config": "workspace:*",
    "@caseweaver/ai-sdk": "workspace:*",
    "@types/node": "22.19.7",
    "@types/pg": "^8.15.6",
    "prisma": "7.8.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
