{
  "name": "@caseweaver/documentation-site",
  "version": "0.0.0",
  "private": true,
  "description": "Standalone CaseWeaver documentation portal.",
  "scripts": {
    "start": "docusaurus start",
    "build": "docusaurus build",
    "serve": "docusaurus serve",
    "clear": "docusaurus clear",
    "typecheck": "tsc --noEmit",
    "test": "node --test tests/*.test.mjs",
    "i18n:write": "docusaurus write-translations",
    "translations:status": "node scripts/translate-docs/status.mjs --check",
    "translations:manifest": "node scripts/translate-docs/status.mjs --write-manifest"
  },
  "dependencies": {
    "@docusaurus/core": "3.10.2",
    "@docusaurus/preset-classic": "3.10.2",
    "@docusaurus/theme-common": "3.10.2",
    "@easyops-cn/docusaurus-search-local": "0.52.2",
    "@mdx-js/react": "3.1.0",
    "clsx": "2.1.1",
    "prism-react-renderer": "2.4.1",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@docusaurus/faster": "3.10.2",
    "@docusaurus/module-type-aliases": "3.10.2",
    "@docusaurus/tsconfig": "3.10.2",
    "@docusaurus/types": "3.10.2",
    "@types/node": "22.19.7",
    "@types/react": "19.2.2",
    "@types/react-dom": "19.2.2",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22.13.0"
  }
}
