# Build context exclusions. Source, Prisma migration history, and the Admin public
# assets remain in context; all local state and generated output are excluded.
.git
.github
.env
.env.*
!.env.example
node_modules
**/node_modules
dist
**/dist
coverage
**/coverage
playwright-report
test-results
tmp
temp
*.log
*.tsbuildinfo
.pnpm-store
.turbo
.cache
**/.cache
**/.DS_Store
