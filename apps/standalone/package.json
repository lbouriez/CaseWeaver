{
  "name": "@caseweaver/standalone",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "bin": {
    "caseweaver-standalone": "./dist/main.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.json",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "vitest run"
  },
  "dependencies": {
    "@caseweaver/api": "workspace:*",
    "@caseweaver/application": "workspace:*",
    "@caseweaver/domain": "workspace:*",
    "@caseweaver/observability": "workspace:*",
    "@caseweaver/scheduler": "workspace:*",
    "@caseweaver/webhook": "workspace:*",
    "@caseweaver/worker": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "22.19.7",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
}
