    "@caseweaver/ai-provider-runtime": "workspace:*",
    "@caseweaver/ai-sdk": "workspace:*",
    "@caseweaver/connector-git-markdown": "workspace:*",
    "@caseweaver/connector-jitbit": "workspace:*",
    "@caseweaver/copilot-sdk-agent": "workspace:*",
    "@caseweaver/domain": "workspace:*",
    "@caseweaver/observability": "workspace:*",
    "@caseweaver/openai-compatible": "workspace:*",
    "@caseweaver/postgres": "workspace:*",
    "@caseweaver/security": "workspace:*",
    "fastify": "^5.0.0",
    "pg": "^8.0.0",
    "pino": "^9.0.0",
    "zod": "^4.0.0"
  },
  "devDependencies": {
    "@types/node": "22.19.7",
    "@types/pg": "^8.0.0",
    "typescript": "5.9.3",
    "vitest": "4.0.18"
  }
